---
import '../../styles/global.css';
import { formatDocListTitle, getDocUrl, getPublishedDocs, groupDocsByTag } from '../../lib/content';
import SeoHead from '../../components/SeoHead.astro';

export async function getStaticPaths() {
  const docs = await getPublishedDocs();
  return groupDocsByTag(docs).map((tag) => ({
    params: { slug: tag.slug },
    props: { tag }
  }));
}

const { tag } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <SeoHead title={`${tag.name} - 标签`} description={`标签 ${tag.name} 下的技术文章。`} path={`/tags/${tag.slug}/`} />
  </head>
  <body>
    <main class="site-shell">
      <section class="hero compact">
        <p class="eyebrow">Tag</p>
        <div class="hero-grid">
          <div>
            <h1>{tag.name}</h1>
            <p class="hero-description">该标签下共有 {tag.items.length} 篇文章。</p>
          </div>
          <a class="primary-link" href="/tags/">全部标签</a>
        </div>
      </section>
      <section class="docs-index single-column">
        <div class="docs-list">
          {
            tag.items.map((doc) => (
              <a class="doc-row" href={getDocUrl(doc.id)}>
                <strong>{formatDocListTitle(doc)}</strong>
                <p>{doc.data.description}</p>
              </a>
            ))
          }
        </div>
      </section>
    </main>
    <script is:inline src="/theme-toggle.js"></script>
  </body>
</html>
