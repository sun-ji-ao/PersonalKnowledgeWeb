---
import '../../styles/global.css';
import { formatDocListTitle, getDocUrl, getOrderedCategories, getPublishedDocs } from '../../lib/content';
import SeoHead from '../../components/SeoHead.astro';

export async function getStaticPaths() {
  const docs = await getPublishedDocs();
  return getOrderedCategories(docs).map((category) => ({
    params: { slug: category.slug },
    props: { category }
  }));
}

const { category } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <SeoHead
      title={`${category.name} - 分类`}
      description={`分类 ${category.name} 下的技术文章。`}
      path={`/categories/${category.slug}/`}
    />
  </head>
  <body>
    <main class="site-shell">
      <section class="hero compact">
        <p class="eyebrow">Category</p>
        <div class="hero-grid">
          <div>
            <h1>{category.name}</h1>
            <p class="hero-description">该分类下共有 {category.items.length} 篇文章。</p>
          </div>
          <a class="primary-link" href="/categories/">全部分类</a>
        </div>
      </section>
      <section class="docs-index single-column">
        <div class="docs-list">
          {
            category.items.map((doc) => (
              <a class="doc-row" href={getDocUrl(doc.id)}>
                <strong>{formatDocListTitle(doc)}</strong>
                <p>{doc.data.description}</p>
              </a>
            ))
          }
        </div>
      </section>
    </main>
    <script is:inline src="/theme-toggle.js"></script>
  </body>
</html>
