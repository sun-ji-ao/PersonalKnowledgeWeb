---
import '../../styles/global.css';
import { SITE_DESCRIPTION, SITE_NAME, getPublishedDocs, groupDocsByCategory, groupDocsByTag } from '../../lib/content';

const docs = await getPublishedDocs();
const categories = groupDocsByCategory(docs);
const tags = groupDocsByTag(docs);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={`${SITE_NAME} 的站点介绍、内容来源和技术栈说明。`} />
    <title>关于 - {SITE_NAME}</title>
  </head>
  <body>
    <main class="site-shell">
      <section class="hero compact">
        <p class="eyebrow">About</p>
        <div class="hero-grid">
          <div>
            <h1>关于本站</h1>
            <p class="hero-description">{SITE_DESCRIPTION}</p>
          </div>
          <a class="primary-link" href="/">返回首页</a>
        </div>
      </section>

      <section class="about-grid">
        <article class="about-card">
          <h2>站点定位</h2>
          <p>
            本站用于整理个人技术知识、学习笔记和结构化 Markdown 文档，当前重点覆盖 Windows、C/C++、
            汇编、逆向、安全研究、内核和网络编程等内容。
          </p>
        </article>

        <article class="about-card">
          <h2>内容规模</h2>
          <p>当前已导入 {docs.length} 篇 Markdown 文档，按 {categories.length} 个分类和 {tags.length} 个标签组织。</p>
        </article>

        <article class="about-card">
          <h2>技术栈</h2>
          <p>网站采用 Astro 静态构建，Pagefind 提供站内搜索，Shiki 提供代码高亮，部署时不需要后端服务。</p>
        </article>

        <article class="about-card">
          <h2>内容更新方式</h2>
          <p>
            将 Markdown 放入仓库内的 `bypassAV-study-main` 目录后，执行构建命令即可自动导入、生成文章页面和搜索索引。
          </p>
        </article>
      </section>
    </main>
    <script is:inline src="/theme-toggle.js"></script>
  </body>
</html>
