---
import '../../styles/global.css';
import {
  buildDocDisplayDateMap,
  formatDisplayDate,
  formatDocListTitle,
  getDocUrl,
  getPublishedDocs
} from '../../lib/content';
import SeoHead from '../../components/SeoHead.astro';

const docs = await getPublishedDocs();
const displayDateMap = buildDocDisplayDateMap(docs);
const archiveMap = new Map<string, typeof docs>();
for (const doc of docs) {
  const displayDate = displayDateMap.get(doc.id)!;
  const key = `${displayDate.getUTCFullYear()}-${String(displayDate.getUTCMonth() + 1).padStart(2, '0')}`;
  const group = archiveMap.get(key) ?? [];
  group.push(doc);
  archiveMap.set(key, group);
}
const archiveGroups = Array.from(archiveMap.entries())
  .sort(([monthA], [monthB]) => monthB.localeCompare(monthA))
  .map(([month, items]) => {
    const sortedItems = items
      .slice()
      .sort((a, b) => displayDateMap.get(b.id)!.getTime() - displayDateMap.get(a.id)!.getTime());
    const [year, monthNumber] = month.split('-');
    return [`${year}年${monthNumber}月`, sortedItems] as const;
  });
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <SeoHead title="归档" description="按时间归档浏览孙计奥 Notes 技术文章。" path="/archive/" />
  </head>
  <body>
    <main class="site-shell">
      <section class="hero compact">
        <p class="eyebrow">Archive</p>
        <div class="hero-grid">
          <div>
            <h1>文章归档</h1>
            <p class="hero-description">按发布时间整理全部文章，方便按年月回顾技术笔记。</p>
          </div>
          <a class="primary-link" href="/docs/">返回知识库</a>
        </div>
      </section>

      <section class="archive-list">
        {
          archiveGroups.map(([month, items]) => (
            <section class="archive-group">
              <div class="archive-month">
                <strong>{month}</strong>
                <span>{items.length} 篇</span>
              </div>
              <div class="archive-items">
                {items.map((doc) => (
                  <a href={getDocUrl(doc.id)}>
                    <strong>{formatDocListTitle(doc)}</strong>
                    <span>{formatDisplayDate(displayDateMap.get(doc.id)!)}</span>
                    <p>{doc.data.description}</p>
                  </a>
                ))}
              </div>
            </section>
          ))
        }
      </section>
    </main>
    <script is:inline src="/theme-toggle.js"></script>
  </body>
</html>
