---
import '../styles/global.css';
import { getDocUrl, getPublishedDocs, groupDocsByCategory, groupDocsByTag } from '../lib/content';

const docs = await getPublishedDocs();
const categories = groupDocsByCategory(docs)
  .sort((a, b) => b.items.length - a.items.length)
  .slice(0, 9)
  .map((category, index) => ({ ...category, active: index === 0 }));

const tags = groupDocsByTag(docs)
  .slice(0, 6)
  .map((tag) => tag.name);

const featuredArticles = ['第一个驱动程序', 'PE文件头解析', 'x86汇编框架']
  .map((title) => docs.find((doc) => doc.data.title.replaceAll(' ', '') === title))
  .filter(Boolean)
  .slice(0, 3);

const fallbackFeaturedArticles = docs.slice(0, 3);
const displayFeaturedArticles = featuredArticles.length > 0 ? featuredArticles : fallbackFeaturedArticles;
const recentUpdates = docs.slice(-4).reverse();

const tocItems = ['环境准备', 'DriverEntry', 'Device Object', 'Build and Debug', 'FAQ'];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="个人技术知识网站，支持 Markdown、代码高亮、分类标签、全文搜索和静态部署。"
    />
    <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
    <title>个人技术知识网站</title>
  </head>
  <body>
    <main class="site-shell">
      <section class="hero">
        <p class="eyebrow">Personal Knowledge Website</p>
        <div class="hero-grid">
          <div>
            <h1>个人技术知识网站</h1>
            <p class="hero-description">
              面向 Markdown 技术文档的极简科技风知识库，适合沉淀 Windows、C/C++、逆向、安全研究和博客文章。
            </p>
          </div>
          <div class="hero-actions" aria-label="站点能力">
            <span>Markdown</span>
            <span>代码高亮</span>
            <span>全文搜索</span>
          </div>
        </div>
      </section>

      <section class="app-frame" aria-label="网站界面预览">
        <header class="topbar">
          <a class="brand" href="/" aria-label="返回首页">
            <span class="brand-mark">孙</span>
            <span>
              <strong>孙计奥 Notes</strong>
              <small>安全研究 / Windows / 技术笔记</small>
            </span>
          </a>
          <div id="search" class="search-box" aria-label="站内全文搜索"></div>
          <nav class="nav-links" aria-label="主导航">
            <a href="/docs/">知识库</a>
            <a href="/categories/">分类</a>
            <a href="/tags/">标签</a>
            <a href="/rss.xml">RSS</a>
            <a href="#about">关于</a>
          </nav>
          <button class="theme-toggle" type="button">Dark</button>
        </header>

        <div class="content-grid">
          <aside class="sidebar" id="knowledge">
            <div class="panel-title">
              <h2>知识分类</h2>
              <p>按 GitHub Markdown 目录生成</p>
            </div>
            <ul class="category-list">
              {
                categories.map((category) => (
                  <li>
                    <a class:list={['category-item', { active: category.active }]} href="/docs/">
                      <span>{category.name}</span>
                      <strong>{category.items.length}</strong>
                    </a>
                  </li>
                ))
              }
            </ul>
            <div class="tag-cloud" aria-label="标签云">
              <h3>标签云</h3>
              <div>
                {tags.map((tag) => <a href="/tags/">{tag}</a>)}
              </div>
            </div>
          </aside>

          <article class="reader">
            <div class="article-head">
              <p>知识库 / Windows 内核安全 / Lesson 02</p>
              <h2>第一个驱动程序</h2>
              <p>
                从 Markdown 文档自动导入，保留层级、标题、代码块、分类标签和文章目录导航。
              </p>
              <div class="article-tags">
                <span>Driver</span>
                <span>Kernel</span>
              </div>
            </div>

            <section class="article-section">
              <h3>文章摘要</h3>
              <p>
                该页面展示技术文档转博客后的阅读效果：左侧用于分类检索，中间专注正文阅读，右侧提供当前文章目录。
              </p>
            </section>

            <section class="article-section">
              <h3>Markdown 正文与代码高亮</h3>
              <pre><code><span class="code-keyword">NTSTATUS</span> DriverEntry(
    <span class="code-type">PDRIVER_OBJECT</span> driverObject
) &#123;
    KdPrint((<span class="code-string">"Hello Kernel"</span>));
    <span class="code-keyword">return</span> STATUS_SUCCESS;
&#125;</code></pre>
            </section>

            <div class="pager">
              <a href="#">上一篇：IRQL Basics</a>
              <a href="#">下一篇：Memory</a>
            </div>
          </article>

          <aside class="right-rail">
            <section class="toc-card">
              <h2>文章目录</h2>
              <ol>
                {tocItems.map((item, index) => <li class={index === 0 ? 'active' : ''}>{item}</li>)}
              </ol>
            </section>

            <section class="blog-card" id="blog">
              <h2>博客化首页预览</h2>
              <p>文档站逐步演进为个人技术博客。</p>
              <a href="#">精选文章卡片</a>
              <a href="#">最近更新列表</a>
              <a href="#">分类 / 标签 / RSS</a>
            </section>
          </aside>
        </div>
      </section>

      <section class="home-sections" aria-label="首页内容模块">
        <div class="section-heading">
          <p class="eyebrow">Blog Ready</p>
          <h2>首页内容模块</h2>
        </div>
        <div class="home-grid">
          <section class="feature-list">
            <h3>精选文章</h3>
            {
              displayFeaturedArticles.map((article) => (
                <a class="article-card" href={getDocUrl(article.id)}>
                  <span>{article.data.category}</span>
                  <strong>{article.data.title}</strong>
                  <p>{article.data.description}</p>
                </a>
              ))
            }
          </section>
          <section class="update-list" id="archive">
            <h3>最近更新</h3>
            <ul>
              {recentUpdates.map((doc) => <li>{doc.data.category} / {doc.data.title}</li>)}
            </ul>
          </section>
          <section class="stack-card" id="about">
            <h3>技术栈</h3>
            <p>Astro + Shiki + Pagefind + Cloudflare Pages</p>
            <p>
              当前功能均可静态生成，不需要后端服务，部署成本低，适合个人知识库和技术博客。
            </p>
          </section>
        </div>
      </section>
    </main>
    <script is:inline src="/pagefind/pagefind-ui.js"></script>
    <script is:inline>
      window.addEventListener('DOMContentLoaded', () => {
        if (!window.PagefindUI) {
          return;
        }
        new window.PagefindUI({
          element: '#search',
          showSubResults: true,
          translations: {
            placeholder: '搜索 Markdown、代码、标签...'
          }
        });
      });
    </script>
  </body>
</html>
