---
import '../styles/global.css';
import SeoHead from '../components/SeoHead.astro';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <SeoHead title="页面不存在" description="页面不存在。" path="/404.html" noindex />
  </head>
  <body>
    <main class="site-shell">
      <section class="not-found-card">
        <p class="eyebrow">404 Not Found</p>
        <h1>页面不存在</h1>
        <p>你访问的页面可能已经移动、重命名，或者当前链接输入有误。</p>
        <div class="not-found-actions">
          <a class="primary-link" href="/">返回首页</a>
          <a class="primary-link secondary" href="/docs/">进入知识库</a>
        </div>
      </section>
    </main>
    <script is:inline src="/theme-toggle.js"></script>
  </body>
</html>
