---
import '../../styles/global.css';
import { getDocUrl, getPublishedDocs } from '../../lib/content';
import { render } from 'astro:content';

export async function getStaticPaths() {
  const docs = await getPublishedDocs();
  return docs.map((doc, index) => ({
    params: { slug: doc.id },
    props: {
      doc,
      previousDoc: docs[index - 1] ?? null,
      nextDoc: docs[index + 1] ?? null
    }
  }));
}

const { doc, previousDoc, nextDoc } = Astro.props;
const { Content, headings } = await render(doc);
const visibleHeadings = headings.filter((heading) => heading.depth > 1 && heading.depth < 4);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={doc.data.description} />
    <title>{doc.data.title} - 孙计奥 Notes</title>
  </head>
  <body>
    <div class="reading-progress"><span data-reading-progress></span></div>
    <main class="site-shell">
      <section class="doc-layout">
        <aside class="doc-side">
          <a class="back-link" href="/docs/">← 返回知识库</a>
          <div class="doc-meta-card">
            <span>分类</span>
            <strong>{doc.data.category}</strong>
          </div>
          <div class="doc-meta-card">
            <span>标签</span>
            <div class="doc-tags">
              {doc.data.tags.map((tag) => <em>{tag}</em>)}
            </div>
          </div>
        </aside>

        <article class="doc-article" data-pagefind-body>
          <header class="doc-header">
            <p>{doc.data.category}</p>
            <h1>{doc.data.title}</h1>
            {doc.data.description && <span>{doc.data.description}</span>}
          </header>
          <div class="markdown-body">
            <Content />
          </div>
          <nav class="doc-pager" aria-label="文章导航">
            {
              previousDoc ? (
                <a href={getDocUrl(previousDoc.id)}>
                  <span>上一篇</span>
                  <strong>{previousDoc.data.title}</strong>
                </a>
              ) : (
                <span class="disabled">已经是第一篇</span>
              )
            }
            {
              nextDoc ? (
                <a href={getDocUrl(nextDoc.id)}>
                  <span>下一篇</span>
                  <strong>{nextDoc.data.title}</strong>
                </a>
              ) : (
                <span class="disabled">已经是最后一篇</span>
              )
            }
          </nav>
        </article>

        <aside class="doc-toc">
          <h2>文章目录</h2>
          {
            visibleHeadings.length > 0 ? (
              <ol>
                {visibleHeadings.map((heading) => (
                  <li class={`depth-${heading.depth}`}>
                    <a href={`#${heading.slug}`}>{heading.text}</a>
                  </li>
                ))}
              </ol>
            ) : (
              <p>本文暂无目录。</p>
            )
          }
        </aside>
      </section>
    </main>
    <button class="back-to-top-button" type="button" data-back-to-top aria-label="返回顶部">↑</button>
    <script is:inline src="/theme-toggle.js"></script>
    <script is:inline src="/reading-enhance.js"></script>
  </body>
</html>
