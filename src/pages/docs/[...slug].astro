---
import '../../styles/global.css';
import { buildDocDisplayDateMap, formatDisplayDate, formatDocListTitle, getCategoryUrl, getDocUrl, getPublishedDocs } from '../../lib/content';
import { render } from 'astro:content';
import SeoHead from '../../components/SeoHead.astro';

export async function getStaticPaths() {
  const docs = await getPublishedDocs();
  const displayDateMap = buildDocDisplayDateMap(docs);
  return docs.map((doc, index) => ({
    params: { slug: doc.id },
    props: {
      doc,
      previousDoc: docs[index - 1] ?? null,
      nextDoc: docs[index + 1] ?? null,
      displayDate: displayDateMap.get(doc.id)!
    }
  }));
}

const { doc, previousDoc, nextDoc, displayDate } = Astro.props;
const { Content, headings } = await render(doc);
const docListTitle = formatDocListTitle(doc);
const visibleHeadings = headings.filter((heading) => heading.depth > 1 && heading.depth < 5);
const displayDateText = formatDisplayDate(displayDate);
const displayDateIso = displayDate.toISOString().slice(0, 10);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <SeoHead title={docListTitle} description={doc.data.description} path={getDocUrl(doc.id)} type="article" />
  </head>
  <body>
    <div class="reading-progress"><span data-reading-progress></span></div>
    <main class="site-shell">
      <section class="doc-layout">
        <aside class="doc-side">
          <nav class="doc-side-nav" aria-label="页面导航">
            <a class="back-link" href="/">← 返回首页</a>
            <a class="back-link" href="/docs/">← 返回知识库</a>
          </nav>
          <div class="doc-meta-card">
            <span>分类</span>
            <a class="doc-meta-link" href={getCategoryUrl(doc.data.category)}>{doc.data.category}</a>
          </div>
          <div class="doc-meta-card">
            <span>标签</span>
            <div class="doc-tags">
              {doc.data.tags.map((tag) => <em>{tag}</em>)}
            </div>
          </div>
          <div class="doc-toc">
            <h2>文章目录</h2>
            {
              visibleHeadings.length > 0 ? (
                <nav aria-label="当前文章目录">
                  {visibleHeadings.map((heading) => (
                    <a class={`depth-${heading.depth}`} href={`#${heading.slug}`}>
                      {heading.text}
                    </a>
                  ))}
                </nav>
              ) : (
                <p>本文暂无目录。</p>
              )
            }
          </div>
        </aside>

        <article class="doc-article" data-pagefind-body>
          <header class="doc-header">
            <p>{doc.data.category}</p>
            <h1>{docListTitle}</h1>
            <p class="doc-header-date">
              <svg class="doc-header-date-icon" viewBox="0 0 24 24" aria-hidden="true">
                <path
                  d="M7 3a1 1 0 0 1 1 1v1h8V4a1 1 0 1 1 2 0v1h1a3 3 0 0 1 3 3v11a3 3 0 0 1-3 3H6a3 3 0 0 1-3-3V8a3 3 0 0 1 3-3h1V4a1 1 0 0 1 1-1Zm13 8H4v8a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-8Z"
                  fill="currentColor"></path>
              </svg>
              <time datetime={displayDateIso}>{displayDateText}</time>
            </p>
          </header>
          <div class="markdown-body">
            <Content />
          </div>
          <nav class="doc-pager" aria-label="文章导航">
            {
              previousDoc ? (
                <a href={getDocUrl(previousDoc.id)}>
                  <span>上一篇</span>
                  <strong>{formatDocListTitle(previousDoc)}</strong>
                </a>
              ) : (
                <span class="disabled">已经是第一篇</span>
              )
            }
            {
              nextDoc ? (
                <a href={getDocUrl(nextDoc.id)}>
                  <span>下一篇</span>
                  <strong>{formatDocListTitle(nextDoc)}</strong>
                </a>
              ) : (
                <span class="disabled">已经是最后一篇</span>
              )
            }
          </nav>
        </article>

      </section>
    </main>
    <button class="back-to-top-button" type="button" data-back-to-top aria-label="返回顶部">↑</button>
    <script is:inline src="/theme-toggle.js"></script>
    <script>
      import { initMermaidDiagrams } from '../../lib/mermaid-client';
      void initMermaidDiagrams();
    </script>
    <script is:inline src="/reading-enhance.js"></script>
  </body>
</html>
