---
import { SITE_NAME } from '../lib/content';

interface CategoryGroup {
  name: string;
  slug: string;
  items: unknown[];
}

interface Props {
  categories: CategoryGroup[];
  activeNav?: 'categories' | 'tags' | 'archive' | 'docs';
}

const { categories, activeNav } = Astro.props;
---

<div class="home-layout">
  <aside class="home-sidebar" aria-label="站点导航">
    <svg class="home-sidebar-grid" viewBox="0 0 240 800" aria-hidden="true" preserveAspectRatio="none">
      <defs>
        <pattern id="home-grid" width="24" height="24" patternUnits="userSpaceOnUse">
          <path d="M24 0H0V24" fill="none" stroke="rgb(56 189 248 / 14%)" stroke-width="0.6" />
        </pattern>
      </defs>
      <rect width="240" height="800" fill="url(#home-grid)" />
      <path d="M0 120 H240" stroke="rgb(56 189 248 / 18%)" stroke-width="0.8" />
      <path d="M0 360 H240" stroke="rgb(167 139 250 / 12%)" stroke-width="0.8" />
    </svg>
    <a class="home-brand" href="/">
      <span class="home-brand-icon" aria-hidden="true">
        <svg viewBox="0 0 40 40" fill="none">
          <path d="M20 2L36 11V29L20 38L4 29V11L20 2Z" stroke="url(#brand-stroke)" stroke-width="1.4" />
          <path d="M20 10L28 15V25L20 30L12 25V15L20 10Z" fill="rgb(56 189 248 / 22%)" stroke="#38bdf8" stroke-width="1" />
          <circle cx="20" cy="20" r="3" fill="#38bdf8" />
          <defs>
            <linearGradient id="brand-stroke" x1="4" y1="2" x2="36" y2="38">
              <stop stop-color="#38bdf8" />
              <stop offset="1" stop-color="#818cf8" />
            </linearGradient>
          </defs>
        </svg>
      </span>
      <span class="home-brand-text">
        <strong>{SITE_NAME}</strong>
        <small>Security / Windows / Notes</small>
      </span>
    </a>
    <form class="home-search" action="/search/" method="get" role="search" aria-label="站内搜索">
      <svg class="home-search-icon" viewBox="0 0 24 24" aria-hidden="true">
        <circle cx="11" cy="11" r="6.5" fill="none" stroke="currentcolor" stroke-width="1.6" />
        <path d="M16 16L21 21" stroke="currentcolor" stroke-width="1.6" stroke-linecap="round" />
      </svg>
      <input name="q" type="search" placeholder="搜索 Markdown、标签..." autocomplete="off" />
    </form>
    <nav class="home-nav" aria-label="主导航">
      <a class:list={['home-nav-link', { active: activeNav === 'categories' }]} href="/categories/">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 6h16M4 12h10M4 18h14" stroke="currentcolor" stroke-width="1.6" stroke-linecap="round" /></svg>
        分类专题
      </a>
      <a class:list={['home-nav-link', { active: activeNav === 'tags' }]} href="/tags/">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 7h7l3 3h6v7H4V7z" fill="none" stroke="currentcolor" stroke-width="1.6" stroke-linejoin="round" /></svg>
        标签
      </a>
      <a class:list={['home-nav-link', { active: activeNav === 'archive' }]} href="/archive/">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 7h14v10H5V7zm2 3h10M7 14h6" stroke="currentcolor" stroke-width="1.6" stroke-linecap="round" /></svg>
        归档
      </a>
      <a class:list={['home-nav-link', { active: activeNav === 'docs' }]} href="/docs/">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 5h12v14H6V5zm3 4h6M9 13h6M9 16h4" stroke="currentcolor" stroke-width="1.6" stroke-linecap="round" /></svg>
        知识库
      </a>
    </nav>
    <section class="home-category-nav" aria-label="分类导航">
      <p class="home-category-label">
        <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M2 4h12v8H2V4zm0-2h5l1 2h6v1H2V2z" fill="currentcolor" /></svg>
        知识分类
      </p>
      <ul>
        {
          categories.map((category) => (
            <li>
              <a href={`/categories/${category.slug}/`}>
                <span class="home-category-name">{category.name}</span>
                <span class="home-category-count">{category.items.length}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </section>
    <div class="home-sidebar-footer">
      <a class="home-nav-link home-rss-link" href="/rss.xml">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 19a2 2 0 1 1 0-4 2 2 0 0 1 0 4zm0-6a9 9 0 0 1 9 9M5 7a15 15 0 0 1 15 15" fill="none" stroke="currentcolor" stroke-width="1.6" stroke-linecap="round" /></svg>
        RSS
      </a>
      <button class="theme-toggle home-theme-toggle" type="button">Dark</button>
    </div>
  </aside>
  <main class="home-main">
    <slot />
  </main>
</div>
